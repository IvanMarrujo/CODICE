{
  "name": "@codice/agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":      "ts-node src/index.ts",
    "build":    "tsc && pkg dist/index.js --targets node18-win-x64 --output dist/codice-agent.exe",
    "simulate": "ts-node src/simulate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar":  "^3.6.0",
    "axios":     "^1.7.0",
    "form-data": "^4.0.0",
    "xlsx":      "^0.18.5"
  },
  "devDependencies": {
    "pkg":         "^5.8.1",
    "typescript":  "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
